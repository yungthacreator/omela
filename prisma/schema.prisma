generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id             String   @id @default(cuid())
  email          String   @unique
  role           String
  source         String?
  ipHash         String?
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([role])
  @@index([createdAt])
}