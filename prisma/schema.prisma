generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitlistEntry {
  id             String   @id @default(cuid())
  email          String   @unique
  role           String
  source         String?
  ipHash         String?
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Referral system
  referralCode   String   @unique @default(cuid())
  referredBy     String?
  referralCount  Int      @default(0)
  rewardUnlocked Boolean  @default(false)

  @@index([role])
  @@index([createdAt])
  @@index([referralCode])
}